# Copy to ~/.config/founders-telegram/env on the Mac mini (chmod 600).
# launchd and sync-and-index.sh source this file.
#
# Secrets and paths only — model slugs live in runtime.json (see below).

# Path to the founders-notes git clone
VAULT_ROOT=/Users/you/founders-notes

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=123456789

# OpenRouter API key (shared by Librarian, Janitor, expand, embeddings)
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Models (optional here; primary control via runtime.json + Telegram) ---
# On first bot start, missing runtime keys are copied from these env vars once.
# After that, use /settings, /setmodel, /setsteps on Telegram (or edit runtime.json).
#
# TELEGRAM_CHAT_MODEL=anthropic/claude-sonnet-4      → runtime librarian_model
# JANITOR_CLEAN_MODEL=groq/llama-3.1-8b-instant      → runtime janitor_clean_model
# OPENROUTER_MODEL=anthropic/claude-sonnet-4         → runtime expand_model
# OPENROUTER_EMBED_MODEL=qwen/qwen3-embedding-8b     → runtime embed_model
# TELEGRAM_MAX_STEPS=5                               → runtime max_steps
# JANITOR_CLEAN_TEMPERATURE=0.2                      → runtime janitor_clean_temperature
#
# Default runtime file: ~/.config/founders-telegram/runtime.json
# FOUNDERS_TELEGRAM_RUNTIME=~/.config/founders-telegram/runtime.json

# GitHub webhook (Mac mini — push to main → sync-and-index.sh via Tailscale Funnel)
# GITHUB_WEBHOOK_SECRET=
# GITHUB_WEBHOOK_PORT=9876
# GITHUB_WEBHOOK_HOST=127.0.0.1

# Optional
# WEB_SEARCH_API_KEY=
