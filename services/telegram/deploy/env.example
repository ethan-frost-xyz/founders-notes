# Copy to ~/.config/founders-telegram/env on the Mac mini (chmod 600).
# launchd and sync-and-index.sh source this file.

# Path to the founders-notes git clone
VAULT_ROOT=/Users/you/founders-notes

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=123456789

# OpenRouter (shared API key; per-feature models)
OPENROUTER_API_KEY=
TELEGRAM_CHAT_MODEL=anthropic/claude-sonnet-4
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
# Janitor paste clean (LLM-first on every paste; try Groq/Cerebras for speed)
JANITOR_CLEAN_MODEL=groq/llama-3.1-8b-instant
# JANITOR_CLEAN_TEMPERATURE=0.2
# Expand subprocess (expand_datapoints_llm.py) when Janitor runs File & expand
OPENROUTER_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional
# TELEGRAM_MAX_STEPS=5
# WEB_SEARCH_API_KEY=
