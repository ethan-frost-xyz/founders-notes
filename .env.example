# Colossus login (free account at https://colossus.com/register/)
COLOSSUS_EMAIL=you@example.com
COLOSSUS_PASSWORD=your-password

# X API v2 (https://developer.x.com/) — x/x_posts_sync.py
# Mac mini: set in ~/.config/founders-telegram/env instead of repo .env
X_BEARER_TOKEN=your-bearer-token
X_USERNAME=ethanfrost

# Optional if lookup-by-username is disabled:
# X_USER_ID=your-numeric-user-id
# Workflow: x_posts_sync.py → x_posts_attribute.py (see import/README.md)
# Optional LLM for review-band attribution: x_posts_attribute.py --llm-review
# X_ATTRIBUTION_MODEL=deepseek/deepseek-v4-flash

# OpenRouter — expand_datapoints_llm.py, expand_tune.py, build_embeddings.py
OPENROUTER_API_KEY=your-openrouter-api-key
# Any slug from https://openrouter.ai/models — swap when tuning cost/speed/quality (optional :nitro suffix)
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
# Parent-tier embeddings — build_embeddings.py, Telegram search_vault_parent (any OpenRouter embedding slug)
# OPENROUTER_EMBED_MODEL=your-provider/your-embedding-model
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
